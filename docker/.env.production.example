# K0 Production Environment — COPY TO SERVER: /home/<user>/k0/docker/.env.production
# DO NOT COMMIT THIS FILE
# Generate strong secrets with: openssl rand -base64 32

NODE_ENV=production
PORT=3002
TRUST_PROXY=1
CORS_ORIGINS=https://k0.yiiling.cn,exp://localhost:8081

# Database (k0-db container)
DB_HOST=k0-db
DB_PORT=3306
DB_USER=k0_user
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DB_NAME=k0

# MySQL root (for initial setup only — remove after setup)
MYSQL_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD

# JWT
JWT_SECRET=REPLACE_WITH_32CHAR_RANDOM_STRING
AUTH_ENABLED=true

# GLM AI
GLM_API_KEY=REPLACE_WITH_REAL_KEY
GLM_MODEL=glm-4-flash

# Logging
LOG_LEVEL=info

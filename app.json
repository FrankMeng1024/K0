{
  "expo": {
    "name": "K0",
    "slug": "k0",
    "version": "0.1.0",
    "scheme": "k0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.yiiling.k0",
      "supportsTablet": false,
      "buildNumber": "1"
    },
    "android": {
      "package": "com.yiiling.k0",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}

{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "channel": "production",
      "ios": {
        "resourceClass": "m-medium",
        "autoIncrement": "buildNumber"
      },
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.k0.yiiling.cn"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "916354835@qq.com",
        "ascAppId": "6787619887",
        "appleTeamId": "X72DH2T8QR"
      }
    }
  }
}

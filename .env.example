# K0 Backend Environment Variables (EXAMPLE)
# 复制此文件为 .env 并填入实际值

# --- Backend Server ---
NODE_ENV=development
PORT=3002
TRUST_PROXY=0
CORS_ORIGINS=http://localhost:8081,http://localhost:8090

# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=k0_user
DB_PASSWORD=<see-secure-store>
DB_NAME=k0_dev

# --- Auth ---
JWT_SECRET=<generate-32-char-random-string-with: openssl rand -base64 32>
AUTH_ENABLED=false

# --- GLM AI ---
GLM_API_KEY=<see-secure-store>
GLM_MODEL=glm-4-plus

# --- Logging ---
LOG_LEVEL=info
